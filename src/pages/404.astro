---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page Not Found" currentPath="/404">
  <main class="page" style="text-align: center; padding-top: 100px;">
    <div style="font-size: 80px; margin-bottom: 24px;">🔍</div>
    <h1 style="font-size: 48px; margin-bottom: 16px;">404</h1>
    <p style="color: var(--color-text-muted); font-size: 18px; margin-bottom: 32px;">Page not found</p>
    <a href="/" class="btn btn-primary">← Back to Home</a>
  </main>
</Base>
