---
import Base from '../layouts/Base.astro';
---

<Base title="Discussion Hub — Sam's Space" currentPath="/hub">
  <div class="banner" style="padding: 32px 24px;">
    <h1 style="font-size: 28px;">💬 Discussion Hub</h1>
    <p style="font-size: 16px; margin-top: 8px;">Chat with Zam — AI, tech, ideas, or just hang out</p>
  </div>

  <main class="page" style="padding-top: 24px;">
    <div class="hub-layout">
      <!-- Sidebar: Topics -->
      <aside class="sidebar">
        <div class="sidebar-card">
          <div class="sidebar-header">
            <h2 style="font-size: 16px; margin: 0;">Topics</h2>
            <button class="new-topic-btn" id="newTopicBtn">+ New</button>
          </div>
          <div class="topic-list" id="topicList">
            <div id="topicListLoading" style="padding: 20px; text-align: center; color: var(--color-text-muted); font-size: 14px;">Loading...</div>
          </div>
        </div>
      </aside>

      <!-- Chat Area -->
      <div class="chat-area">
        <div class="chat-header">
          <h2 id="chatTitle" style="font-size: 16px; margin: 0;">Select a topic to start chatting</h2>
          <div class="chat-status">
            <div class="status-badge">
              <div class="status-dot"></div>
              <span>Zam Online</span>
            </div>
          </div>
        </div>

        <div class="chat-messages" id="chatMessages">
          <div class="empty-state">
            <div style="text-align: center; padding: 60px 20px; color: var(--color-text-muted);">
              <div style="font-size: 48px; margin-bottom: 16px;">💬</div>
              <p style="font-size: 15px;">Choose a topic or create a new one to start the conversation</p>
            </div>
          </div>
        </div>

        <div class="chat-input-area">
          <input type="text" id="messageInput" placeholder="Type your message... (Enter to send)" onkeypress="if(event.key==='Enter')sendMessage()" disabled />
          <button id="sendBtn" onclick="sendMessage()" disabled>Send</button>
        </div>
      </div>
    </div>
  </main>
</Base>

<!-- New Topic Modal -->
<div id="newTopicModal" class="modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
  <div class="modal-content card" style="width: 400px; max-width: 90vw;">
    <h3 style="margin-bottom: 16px;">New Topic</h3>
    <input type="text" id="newTopicTitle" placeholder="Topic title..." style="width:100%; padding:10px; border:1px solid var(--color-border); border-radius:8px; margin-bottom:12px; font-size:15px;" />
    <div style="display:flex; gap:8px; justify-content:flex-end;">
      <button onclick="closeNewTopicModal()" style="padding:8px 16px; border:1px solid var(--color-border); background:white; border-radius:8px; cursor:pointer;">Cancel</button>
      <button onclick="createTopic()" style="padding:8px 16px; background:var(--color-primary); color:white; border:none; border-radius:8px; cursor:pointer;">Create</button>
    </div>
  </div>
</div>

<style>
  .hub-layout { display: flex; gap: 20px; min-height: 600px; }
  .sidebar { width: 280px; flex-shrink: 0; }
  .sidebar-card { background: white; border-radius: 12px; box-shadow: var(--shadow-sm); overflow: hidden; border: 1px solid var(--color-border); }
  .sidebar-header { padding: 16px 20px; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; }
  .new-topic-btn { background: var(--color-primary); color: white; border: none; padding: 6px 14px; border-radius: 20px; cursor: pointer; font-size: 13px; }
  .new-topic-btn:hover { background: var(--color-primary-dark); }
  .topic-list { max-height: 500px; overflow-y: auto; }
  .topic-item { padding: 12px 20px; border-bottom: 1px solid #f0f0f0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: background 0.2s; }
  .topic-item:hover { background: #f8f9fa; }
  .topic-item.active { background: #f0f4ff; border-left: 3px solid var(--color-primary); }
  .topic-title { font-size: 14px; color: #333; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .topic-delete { opacity: 0; color: #999; padding: 4px 8px; border: none; background: none; cursor: pointer; border-radius: 4px; font-size: 16px; transition: all 0.2s; }
  .topic-item:hover .topic-delete { opacity: 1; }
  .topic-delete:hover { background: #ffebee; color: #e53935; }

  .chat-area { flex: 1; background: white; border-radius: 12px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; border: 1px solid var(--color-border); overflow: hidden; }
  .chat-header { padding: 16px 20px; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; }
  .chat-status { display: flex; gap: 15px; }
  .status-badge { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #666; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #4CAF50; box-shadow: 0 0 0 2px rgba(76,175,80,0.3); }

  .chat-messages { flex: 1; padding: 20px; overflow-y: auto; max-height: 450px; }

  .message { display: flex; gap: 12px; margin-bottom: 16px; }
  .message.human { flex-direction: row-reverse; }
  .message-avatar { width: 36px; height: 36px; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .message-content { max-width: 70%; }
  .message-header { display: flex; gap: 8px; align-items: baseline; margin-bottom: 4px; font-size: 12px; }
  .message-name { font-weight: 600; color: #333; }
  .message.human .message-name { color: var(--color-primary); }
  .message-time { color: #999; }
  .message-bubble { padding: 10px 14px; border-radius: 16px; font-size: 14px; line-height: 1.5; background: #f0f2f5; color: #333; }
  .message.human .message-bubble { background: var(--color-primary); color: white; }

  .chat-input-area { padding: 16px 20px; border-top: 1px solid var(--color-border); display: flex; gap: 10px; }
  .chat-input-area input { flex: 1; padding: 10px 14px; border: 1px solid var(--color-border); border-radius: 8px; font-size: 14px; outline: none; }
  .chat-input-area input:focus { border-color: var(--color-primary); }
  .chat-input-area input:disabled { background: #f9f9f9; color: #999; }
  #sendBtn { padding: 10px 20px; background: var(--color-primary); color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 600; }
  #sendBtn:disabled { background: #ccc; cursor: not-allowed; }

  @media (max-width: 768px) {
    .hub-layout { flex-direction: column; }
    .sidebar { width: 100%; }
  }
</style>

<script define:vars={{ supabaseUrl: 'https://babkatqycaigexyjnlqv.supabase.co', supabaseKey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJhYmthdHF5Y2FpZ2V4eWpubHF2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxMzg4NjksImV4cCI6MjA4ODcxNDg2OX0.xnz8BHhA8dThSpwOBoeubNCIfUXLmEuknf3S0niuwCk' }}>
  const API_URL = supabaseUrl;
  const API_KEY = supabaseKey;
  let currentTopicId = null;
  let pollInterval = null;

  // Update all API calls with the new JWT key
  const AUTH_HEADER = 'Bearer ' + API_KEY;

  // Load topics on page load
  loadTopics();

  // New topic modal
  document.getElementById('newTopicBtn').addEventListener('click', () => {
    document.getElementById('newTopicModal').style.display = 'flex';
    document.getElementById('newTopicTitle').focus();
  });

  function closeNewTopicModal() {
    document.getElementById('newTopicModal').style.display = 'none';
    document.getElementById('newTopicTitle').value = '';
  }

  async function createTopic() {
    const title = document.getElementById('newTopicTitle').value.trim();
    if (!title) return;
    const res = await fetch(API_URL + '/rest/v1/topics', {
      method: 'POST',
      headers: { 'apikey': API_KEY, 'Authorization': 'Bearer ' + API_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
      body: JSON.stringify({ title, status: 'active', created_by: 'Sam' })
    });
    if (res.ok) {
      closeNewTopicModal();
      loadTopics();
    }
  }

  async function loadTopics() {
    const res = await fetch(API_URL + '/rest/v1/topics?status=eq.active&order=created_at.desc', {
      headers: { 'apikey': API_KEY, 'Authorization': 'Bearer ' + API_KEY }
    });
    if (!res.ok) return;
    const topics = await res.json();
    const container = document.getElementById('topicList');
    if (topics.length === 0) {
      container.innerHTML = '<div style="padding:20px; text-align:center; color:#999; font-size:14px;">No topics yet. Start one!</div>';
      return;
    }
    container.innerHTML = topics.map(t => `
      <div class="topic-item${t.id === currentTopicId ? ' active' : ''}" onclick="selectTopic(${t.id}, '${t.title.replace(/'/g, "\\'")}')">
        <span class="topic-title">${escHtml(t.title)}</span>
        <button class="topic-delete" onclick="deleteTopic(${t.id}, event)" title="Delete">×</button>
      </div>
    `).join('');
  }

  async function selectTopic(id, title) {
    currentTopicId = id;
    document.getElementById('chatTitle').textContent = title;
    document.getElementById('messageInput').disabled = false;
    document.getElementById('sendBtn').disabled = false;
    document.getElementById('messageInput').focus();
    if (pollInterval) clearInterval(pollInterval);
    await loadMessages(id);
    pollInterval = setInterval(() => loadMessages(id, true), 3000);
    loadTopics();
  }

  async function loadMessages(topicId, isSilent = false) {
    const res = await fetch(API_URL + '/rest/v1/messages?topic_id=eq.' + topicId + '&order=created_at.asc', {
      headers: { 'apikey': API_KEY, 'Authorization': 'Bearer ' + API_KEY }
    });
    if (!res.ok) return;
    const msgs = await res.json();
    renderMessages(msgs, isSilent);
  }

  function renderMessages(msgs, isSilent = false) {
    const container = document.getElementById('chatMessages');
    if (msgs.length === 0) {
      container.innerHTML = '<div style="text-align:center; padding:60px 20px; color:#999;"><div style="font-size:48px; margin-bottom:16px;">💬</div><p>Start the conversation!</p></div>';
      return;
    }
    container.innerHTML = msgs.map(m => {
      const avatar = m.author_type === 'zam' ? '🤖' : '👤';
      const time = new Date(m.created_at).toLocaleTimeString('zh-CN', {hour:'2-digit', minute:'2-digit', timeZone:'Asia/Shanghai'});
      return `<div class="message ${m.author_type === 'human' ? 'human' : ''}">
        <div class="message-avatar">${avatar}</div>
        <div class="message-content">
          <div class="message-header"><span class="message-name">${escHtml(m.author)}</span><span class="message-time">${time}</span></div>
          <div class="message-bubble">${escHtml(m.content)}</div>
        </div>
      </div>`;
    }).join('');
    if (!isSilent) container.scrollTop = container.scrollHeight;
  }

  async function sendMessage() {
    const input = document.getElementById('messageInput');
    const content = input.value.trim();
    if (!content || !currentTopicId) return;
    input.value = '';
    await fetch(API_URL + '/rest/v1/messages', {
      method: 'POST',
      headers: { 'apikey': API_KEY, 'Authorization': 'Bearer ' + API_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
      body: JSON.stringify({ topic_id: currentTopicId, author: 'Sam', author_type: 'human', content })
    });
    await loadMessages(currentTopicId);
  }

  async function deleteTopic(id, event) {
    event.stopPropagation();
    if (!confirm('Delete this topic and all its messages?')) return;
    await fetch(API_URL + '/rest/v1/messages?topic_id=eq.' + id, {
      method: 'DELETE', headers: { 'apikey': API_KEY, 'Authorization': 'Bearer ' + API_KEY }
    });
    await fetch(API_URL + '/rest/v1/topics?id=eq.' + id, {
      method: 'DELETE', headers: { 'apikey': API_KEY, 'Authorization': 'Bearer ' + API_KEY }
    });
    if (currentTopicId === id) {
      currentTopicId = null;
      document.getElementById('chatTitle').textContent = 'Select a topic';
      document.getElementById('chatMessages').innerHTML = '<div style="text-align:center; padding:60px 20px; color:#999;"><div style="font-size:48px; margin-bottom:16px;">💬</div><p>Choose a topic to start</p></div>';
      document.getElementById('messageInput').disabled = true;
      document.getElementById('sendBtn').disabled = true;
    }
    loadTopics();
  }

  function escHtml(text) {
    const d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }
</script>
