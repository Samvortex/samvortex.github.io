---
import Base from '../layouts/Base.astro';
---

<Base title="About — Sam's Space" currentPath="/about">
  <section class="banner">
    <h1>About</h1>
    <p>IT Architect · AI Enthusiast · Builder</p>
  </section>

  <main class="page">
    <div class="grid grid-2" style="align-items: start;">
      <div>
        <div class="card" style="margin-bottom: 24px;">
          <h2 style="font-size: 22px; margin-bottom: 16px;">Who I Am</h2>
          <p style="color: var(--color-text-muted); line-height: 1.8; margin-bottom: 12px;">
            IT System Architect at <strong>Wellington College China</strong>, managing infrastructure across the group's schools in Shanghai, Hangzhou, Nantong, andTianjin.
          </p>
          <p style="color: var(--color-text-muted); line-height: 1.8;">
            Based in Shanghai's Qianpu (前滩) area, near the Oriental Sports Center. Passionate about AI agents, automation, and building tools that make life better.
          </p>
        </div>

        <div class="card">
          <h2 style="font-size: 22px; margin-bottom: 16px;">What I Do</h2>
          <ul style="color: var(--color-text-muted); line-height: 2; padding-left: 20px;">
            <li>Manage IT infrastructure across Wellington China schools</li>
            <li>Build AI-powered tools (Zam, Vortex, Jira agents)</li>
            <li>Explore automation, productivity, and local AI deployment</li>
            <li>Personal projects: discussion hubs, monitoring systems</li>
          </ul>
        </div>
      </div>

      <div>
        <div class="card" style="margin-bottom: 24px;">
          <h2 style="font-size: 22px; margin-bottom: 16px;">⚡ AI Agents</h2>
          <div style="margin-bottom: 16px;">
            <strong>Zam</strong> — Discord assistant, my main AI agent running on OpenClaw
          </div>
          <div style="margin-bottom: 16px;">
            <strong>Vortex</strong> — Feishu bot, work-focused agent
          </div>
          <div>
            <strong>Jira</strong> — Feishu bot, second AI agent for specialized tasks
          </div>
        </div>

        <div class="card">
          <h2 style="font-size: 22px; margin-bottom: 16px;">🌍 Wellington College</h2>
          <p style="color: var(--color-text-muted); line-height: 1.8;">
            Part of the global Wellington College network, founded in 1859 by Queen Victoria. 
            10+ schools across UK, China, India, Thailand, and more.
          </p>
          <p style="color: var(--color-text-muted); line-height: 1.8; margin-top: 12px;">
            <strong>Core Values:</strong> Kindness · Responsibility · Respect · Courage · Integrity
          </p>
        </div>
      </div>
    </div>
  </main>
</Base>
